# ===================================
# WiFi Network System - Environment Variables
# ===================================
# Copy this file to .env and fill in your values

# Database (Neon.tech PostgreSQL)
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/wifi_network?sslmode=require

# JWT Authentication
JWT_SECRET=change-this-to-a-strong-random-secret-at-least-32-chars

# Server
NODE_ENV=development
PORT=3000

# CORS - Comma-separated allowed origins (NO spaces)
# Example: http://localhost:5173,https://your-app.vercel.app
ALLOWED_ORIGINS=http://localhost:5173

# Socket.io (optional - for future real-time features)
# SOCKETIO_ENABLED=true
